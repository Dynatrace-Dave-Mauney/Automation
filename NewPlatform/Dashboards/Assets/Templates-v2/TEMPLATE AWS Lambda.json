    "tiles": {
        "0": {
            "type": "data",
            "title": "LambdaFunction concurrent executions count",
            "query": "timeseries conc_executions = avg(dt.cloud.aws.lambda.conc_executions), by: { dt.entity.aws_lambda_function }\n| sort arrayAvg(conc_executions) desc\n| limit 20",
