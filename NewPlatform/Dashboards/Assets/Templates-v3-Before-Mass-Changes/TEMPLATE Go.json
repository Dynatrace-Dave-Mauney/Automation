    "tiles": {
        "0": {
            "title": "Total requests",
            "type": "data",
            "query": "/*\nWarning:\n - Rollup `value` is not supported in DQL.\n*/\ntimeseries requests = avg(dt.runtime.go.http.requests), by: { dt.entity.process_group_instance }\n| sort arrayAvg(requests) desc\n| limit 20",
            "visualization": "lineChart",
            "visualizationSettings": {
                "autoSelectVisualization": false,
                "unitsOverrides": []
            },
            "davis": {
                "enabled": false,
                "davisVisualization": {
                    "isAvailable": true
                }
            }
        },
