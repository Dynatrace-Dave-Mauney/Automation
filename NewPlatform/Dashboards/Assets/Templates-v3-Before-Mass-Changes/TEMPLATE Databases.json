{
    "version": 21,
    "variables": [],
    "tiles": {
        "4": {
            "title": "Requests",
            "type": "data",
            "query": "timeseries count = avg(dt.service.request.count, filter: { in(dt.entity.service, classicEntitySelector(\"type(service),servicetype(\\\"DATABASE_SERVICE\\\")\")) }), by: { dt.entity.service }\n| fieldsAdd name=entityAttr(dt.entity.service, \"entity.name\")\n| sort arrayAvg(count) desc\n| limit 20",
            "visualization": "lineChart",
            "visualizationSettings": {
                "autoSelectVisualization": false,
                "unitsOverrides": [],
                "dataMapping": {
                    "displayedFields": [
                        "name"
                    ]
                }
            },
            "davis": {
                "enabled": false,
                "davisVisualization": {
                    "isAvailable": true
                }
            },
            "querySettings": {
                "maxResultRecords": 1000,
                "defaultScanLimitGbytes": 500,
                "maxResultMegaBytes": 1,
                "defaultSamplingRatio": 10,
                "enableSampling": false
            }
        },
        "5": {
            "title": "Response time - Median",
            "type": "data",
            "query": "timeseries response_time = percentile(dt.service.request.response_time, 50, filter: { in(dt.entity.service, classicEntitySelector(\"type(service),servicetype(\\\"DATABASE_SERVICE\\\")\")) }), by: { dt.entity.service }\n| fieldsAdd name=entityAttr(dt.entity.service, \"entity.name\")\n| sort arrayPercentile(response_time, 50) desc\n| limit 20",
            "visualization": "lineChart",
            "visualizationSettings": {
                "autoSelectVisualization": false,
                "unitsOverrides": [],
                "dataMapping": {
                    "displayedFields": [
                        "name"
                    ]
                }
            },
            "davis": {
                "enabled": false,
                "davisVisualization": {
                    "isAvailable": true
                }
            },
            "querySettings": {
                "maxResultRecords": 1000,
                "defaultScanLimitGbytes": 500,
                "maxResultMegaBytes": 1,
                "defaultSamplingRatio": 10,
                "enableSampling": false
            }
        },
        "6": {
            "title": "Response time - Slowest 10%",
            "type": "data",
            "query": "timeseries response_time = percentile(dt.service.request.response_time, 50, filter: { in(dt.entity.service, classicEntitySelector(\"type(service),servicetype(\\\"DATABASE_SERVICE\\\")\")) }), by: { dt.entity.service }\n| fieldsAdd name=entityAttr(dt.entity.service, \"entity.name\")\n| sort arrayPercentile(response_time, 50) desc\n| limit 20",
            "visualization": "lineChart",
            "visualizationSettings": {
                "autoSelectVisualization": false,
                "unitsOverrides": [],
                "dataMapping": {
                    "displayedFields": [
                        "name"
                    ]
                }
            },
            "davis": {
                "enabled": false,
                "davisVisualization": {
                    "isAvailable": true
                }
            },
            "querySettings": {
                "maxResultRecords": 1000,
                "defaultScanLimitGbytes": 500,
                "maxResultMegaBytes": 1,
                "defaultSamplingRatio": 10,
                "enableSampling": false
            }
        },
        "10": {
            "title": "Failure rate",
            "type": "data",
            "query": "timeseries { failure_count = sum(dt.service.request.failure_count), count = sum(dt.service.request.count) }, by: { dt.entity.service }, filter: { in(dt.entity.service, classicEntitySelector(\"type(service),servicetype(\\\"DATABASE_SERVICE\\\")\")) }\n| fieldsAdd rate = failure_count[] / count[]\n| fieldsAdd name=entityAttr(dt.entity.service, \"entity.name\")\n| sort arrayAvg(rate) desc\n| fieldsRemove failure_count, count\n| limit 20",
            "visualization": "lineChart",
            "visualizationSettings": {
                "autoSelectVisualization": false,
                "unitsOverrides": [],
                "dataMapping": {
                    "displayedFields": [
                        "name"
                    ]
                }
            },
            "davis": {
                "enabled": false,
                "davisVisualization": {
                    "isAvailable": true
                }
            },
            "querySettings": {
                "maxResultRecords": 1000,
                "defaultScanLimitGbytes": 500,
                "maxResultMegaBytes": 1,
                "defaultSamplingRatio": 10,
                "enableSampling": false
            }
        }
    },
