    "tiles": {
        "0": {
            "type": "data",
            "title": "DNSQueries",
            "query": "timeseries dns_queries = avg(cloud.aws.route53.dns_queries), by: { dt.entity.custom_device }\n| fieldsAdd name=entityAttr(dt.entity.custom_device, \"entity.name\")\n| sort arrayAvg(dns_queries) desc\n| limit 20",
            "davis": {
                "enabled": false,
                "davisVisualization": {
                    "isAvailable": true
                }
            },
            "visualizationSettings": {
                "unitsOverrides": [],
                "dataMapping": {
                    "displayedFields": [
                        "name"
                    ]
                }
            },
            "visualization": "lineChart"
        },
        "1": {
            "type": "data",
            "title": "DNSQueries Sum",
            "query": "/*\nWarning:\n - Rollup `value` is not supported in DQL.\n*/\ntimeseries dns_queries_sum = avg(cloud.aws.route53.dns_queries_sum), by: { dt.entity.custom_device }\n| fieldsAdd name=entityAttr(dt.entity.custom_device, \"entity.name\")\n| sort arrayAvg(dns_queries_sum) desc\n| limit 20",
            "davis": {
                "enabled": false,
