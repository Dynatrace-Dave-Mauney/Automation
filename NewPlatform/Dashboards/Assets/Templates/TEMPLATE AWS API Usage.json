        "2": {
            "title": "ResourceCount Average (by Class and Resource and Type)",
            "type": "data",
            "query": "timeseries resource_count_average_by_class_resource_type = avg(cloud.aws.usage.resource_count_average_by_class_resource_type), by: { Class, Resource, Type }\n| sort arrayAvg(resource_count_average_by_class_resource_type) desc\n| limit 20",
            "visualization": "barChart",
            "visualizationSettings": {
                "autoSelectVisualization": false,
                "unitsOverrides": []
            },
            "davis": {
                "enabled": false,
                "davisVisualization": {
                    "isAvailable": true
                }
            }
        },
        "3": {
            "title": "CallCount Sum (by Class and Resource and Type)",
            "type": "data",
            "query": "timeseries call_count_sum_by_class_resource_type = sum(cloud.aws.usage.call_count_sum_by_class_resource_type), by: { Resource }\n| sort arraySum(call_count_sum_by_class_resource_type) desc\n| limit 20",
            "visualization": "barChart",
            "visualizationSettings": {
                "autoSelectVisualization": false,
                "unitsOverrides": []
            },
            "davis": {
