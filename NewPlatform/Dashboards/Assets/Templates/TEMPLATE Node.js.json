    "tiles": {
        "0": {
            "title": "Node.js: Active handles",
            "type": "data",
            "query": "timeseries avg(dt.runtime.nodejs.eventloop.active_handles), by: { dt.entity.process_group_instance }\n| fieldsAdd runtime.nodejs.eventloop.active_handles = ArrayAvg(`avg(dt.runtime.nodejs.eventloop.active_handles)`)\n| fieldsAdd name=entityAttr(dt.entity.process_group_instance, \"entity.name\")\n| sort runtime.nodejs.eventloop.active_handles desc\n| limit 20",
            "visualization": "lineChart",
            "visualizationSettings": {
                "chartSettings": {
                    "truncationMode": "middle",
                    "legend": {
                        "position": "right"
                    },
                    "leftYAxisSettings": {
                        "label": "runtime.nodejs.eventloop.active_handles"
                    },
                    "xAxisLabel": "timeframe",
                    "xAxisScaling": "analyzedTimeframe",
                    "fieldMapping": {
                        "leftAxisValues": [
                            "avg(dt.runtime.nodejs.eventloop.active_handles)"
                        ],
                        "timestamp": "timeframe"
                    }
                },
                "coloring": {
                    "colorRules": [
                        {
                            "field": "DT.name",
                            "comparator": "= *value*",
                            "value": "",
                            "type": "string",
                            "colorMode": "color-palette",
                            "colorPalette": "categorical"
                        }
                    ]
                },
                "autoSelectVisualization": false,
                "dataMapping": {
                    "displayedFields": [
                        "name"
                    ]
                }
            },
            "querySettings": {
                "maxResultRecords": 1000,
                "defaultScanLimitGbytes": 500,
                "maxResultMegaBytes": 1,
                "defaultSamplingRatio": 10,
                "enableSampling": false
            },
            "davis": {
                "enabled": false,
                "davisVisualization": {
                    "isAvailable": true
                }
            }
        },
