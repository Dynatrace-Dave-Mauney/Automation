{
    "version": 21,
    "variables": [
        {
            "version": 2,
            "key": "ManagementZone",
            "type": "code",
            "visible": true,
            "input": "import { settingsObjectsClient } from \"@dynatrace-sdk/client-classic-environment-v2\";\nexport default async function () {\n  let mzs = [];\n  let data = await settingsObjectsClient.getSettingsObjects({\n    schemaIds: \"builtin:management-zones\",\n    pageSize: 500\n  });\n  mzs = data.items;\n  if(data.hasOwnProperty(\"nextPageKey\") && data.nextPageKey != null){\n    const q = await next(data.nextPageKey);\n  }\n  let arr = [];\n  (mzs).map(result => {\n    arr.push(result.value.name);\n  });\n  console.log(mzs.length);\n  return [\"Select a Management Zone\"].concat(arr.sort());\n  async function next(npk){\n    const more = await settingsObjectsClient.getSettingsObjects({nextPageKey: npk});\n    console.log(more);\n    mzs = mzs.concat(more.items);\n    if(more.hasOwnProperty(\"nextPageKey\") && more.nextPageKey != null) return await next(more.nextPageKey);\n    else return 1;\n  }\n}",
            "multiple": false
        }
    ],
    "tiles": {
        "0": {
            "title": "Node.js: Active handles",
            "type": "data",
            "query": "timeseries avg(dt.runtime.nodejs.eventloop.active_handles), by: { dt.entity.process_group_instance }, \nfilter:dt.entity.process_group_instance in [fetch dt.entity.process_group_instance | filter in(managementZones, $ManagementZone) | fields id]\n| fieldsAdd runtime.nodejs.eventloop.active_handles = ArrayAvg(`avg(dt.runtime.nodejs.eventloop.active_handles)`)\n| fieldsAdd name=entityAttr(dt.entity.process_group_instance, \"entity.name\")\n| sort runtime.nodejs.eventloop.active_handles desc\n| limit 20",
            "visualization": "lineChart",
            "visualizationSettings": {
                "chartSettings": {
                    "truncationMode": "middle",
                    "legend": {
                        "position": "right"
                    },
                    "leftYAxisSettings": {
                        "label": "runtime.nodejs.eventloop.active_handles"
                    },
                    "xAxisLabel": "timeframe",
                    "xAxisScaling": "analyzedTimeframe",
                    "fieldMapping": {
                        "leftAxisValues": [
                            "avg(dt.runtime.nodejs.eventloop.active_handles)"
                        ],
                        "timestamp": "timeframe"
                    }
                },
                "coloring": {
                    "colorRules": [
                        {
                            "field": "DT.name",
                            "comparator": "= *value*",
                            "value": "",
                            "type": "string",
                            "colorMode": "color-palette",
                            "colorPalette": "categorical"
                        }
                    ]
                },
                "autoSelectVisualization": false,
                "dataMapping": {
                    "displayedFields": [
