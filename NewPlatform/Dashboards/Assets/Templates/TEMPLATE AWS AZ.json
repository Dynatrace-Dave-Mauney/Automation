            "title": "Number of running EC2 instances (AZ)",
            "query": "timeseries running = avg(dt.cloud.aws.az.running), by: { dt.entity.aws_credentials }\n| fieldsAdd name=entityAttr(dt.entity.aws_credentials, \"entity.name\")\n| sort arrayAvg(running) desc\n| limit 20",
