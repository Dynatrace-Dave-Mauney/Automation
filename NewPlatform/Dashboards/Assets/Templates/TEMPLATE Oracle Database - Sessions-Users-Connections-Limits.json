        "2": {
            "type": "data",
            "title": "Total sessions",
            "query": "timeseries all = avg(`com.dynatrace.extension.sql-oracle.sessions.all`), by: { `dt.entity.sql:com_dynatrace_extension_sql-oracle_instance` }\n| sort arrayAvg(all) desc\n| limit 20",
