{
  "version": 21,
  "variables": [],
  "tiles": {
    "1": {
      "type": "data",
      "title": "LambdaFunction concurrent executions count",
      "query": "timeseries conc_executions = avg(dt.cloud.aws.lambda.conc_executions), by: {dt.entity.aws_lambda_function}",
      "visualization": "lineChart",
      "visualizationSettings": {
        "legend": {
          "hidden": true
        }
      }
    },
    "2": {
      "type": "data",
      "title": "LambdaFunction code execution time.",
      "query": "timeseries duration = avg(dt.cloud.aws.lambda.duration), by: {dt.entity.aws_lambda_function}",
      "visualization": "lineChart",
      "visualizationSettings": {
        "legend": {
          "hidden": true
        }
      }
    },
    "3": {
      "type": "data",
      "title": "LambdaFunction number of failed invocations with HTTP 4XX status code",
      "query": "timeseries errors = avg(dt.cloud.aws.lambda.errors), by: {dt.entity.aws_lambda_function}",
      "visualization": "lineChart",
      "visualizationSettings": {
        "legend": {
          "hidden": true
        }
      }
    },
    "4": {
      "type": "data",
      "title": "LambdaFunction rate of failed invocations to all invocations %",
      "query": "timeseries errors_rate = avg(dt.cloud.aws.lambda.errors_rate), by: {dt.entity.aws_lambda_function}",
      "visualization": "lineChart",
      "visualizationSettings": {
        "legend": {
          "hidden": true
        }
      }
    },
    "5": {
      "type": "data",
      "title": "LambdaFunction number of times a function is invoked",
      "query": "timeseries invocations = avg(dt.cloud.aws.lambda.invocations), by: {dt.entity.aws_lambda_function}",
      "visualization": "lineChart",
      "visualizationSettings": {
        "legend": {
          "hidden": true
        }
      }
    },
    "6": {
      "type": "data",
      "title": "LambdaFunction throttled function invocation count",
      "query": "timeseries throttlers = avg(dt.cloud.aws.lambda.throttlers), by: {dt.entity.aws_lambda_function}",
      "visualization": "lineChart",
      "visualizationSettings": {
        "legend": {
          "hidden": true
        }
      }
    }
  },
