{
  "version": 21,
  "variables": [],
  "tiles": {
    "1": {
      "type": "data",
      "title": "Number of running EC2 instances (AZ)",
      "query": "timeseries running = avg(dt.cloud.aws.az.running), by: {dt.entity.aws_credentials}",
      "visualization": "lineChart",
      "visualizationSettings": {
        "legend": {
          "hidden": true
        }
      }
    },
    "2": {
      "type": "data",
      "title": "Number of stopped EC2 instances (AZ)",
