    "5": {
      "type": "data",
      "title": "Data explorer results",
      "query": "timeseries usage = avg(dt.host.cpu.usage),\n  by: { dt.entity.host }\n| fieldsAdd host_name = entityName(dt.entity.host)\n| sort arrayAvg(usage) desc\n| limit 10",
      "visualization": "categoricalBarChart",
      "visualizationSettings": {
        "legend": {
          "hidden": true
        },
        "isValueLabelVisible": false,
        "isCategoryLabelVisible": false,
        "chartSettings": {
          "categoricalBarChartSettings": {
            "categoryAxis": [
              "host_name"
            ]
          }
        }
      }
    },
