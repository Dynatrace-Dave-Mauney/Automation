{
  "version": 21,
  "variables": [],
  "tiles": {
    "1": {
      "type": "data",
      "title": "DNSQueries",
      "query": "timeseries dns_queries = avg(cloud.aws.route53.dns_queries), by: {dt.entity.custom_device}",
      "visualization": "lineChart",
      "visualizationSettings": {
        "legend": {
          "hidden": true
        }
      }
    },
    "2": {
      "type": "data",
      "title": "DNSQueries Sum",
      "query": "timeseries dns_queries_sum = avg(cloud.aws.route53.dns_queries_sum), by: {dt.entity.custom_device}",
      "visualization": "lineChart",
      "visualizationSettings": {
        "legend": {
          "hidden": true
        }
      }
    }
  },
  "layouts": {
    "1": {
      "x": 0,
      "y": 0,
      "w": 12,
      "h": 8
    },
    "2": {
      "x": 12,
      "y": 0,
      "w": 12,
      "h": 8
    }
  }
}
