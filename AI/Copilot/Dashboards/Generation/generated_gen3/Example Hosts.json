  "tiles": {
    "1": {
      "type": "data",
      "title": "CPU usage",
      "query": "timeseries usage = avg(dt.host.cpu.usage), by: {dt.entity.host}\n| fieldsAdd usage_value = arrayAvg(usage)\n| fields dt.entity.host, usage_value\n| sort usage_value desc\n| limit 20",
      "visualization": "categoricalBarChart",
      "visualizationSettings": {
        "legend": {
          "hidden": true
        },
        "isValueLabelVisible": false,
        "isCategoryLabelVisible": false
      }
    },
